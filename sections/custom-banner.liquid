<div class="custom-banner" style="background-color: {{ section.settings.bg_color }}; padding: 40px; text-align: center;">
  <h2>{{ section.settings.heading_text }}</h2>
  
  <div class="banner-blocks">
    {% for block in section.blocks %}
      <div class="banner-block" {{ block.shopify_attributes }}>
        {% case block.type %}
          {% when 'paragraph' %}
            <p>{{ block.settings.text }}</p>
          {% when 'button' %}
            <a href="{{ block.settings.link }}" class="btn">{{ block.settings.label }}</a>
        {% endcase %}
      </div>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Custom Dynamic Banner",
  "tag": "section",
  "class": "section-custom-banner",
  "settings": [
    {
      "type": "text",
      "id": "heading_text",
      "label": "Banner Heading",
      "default": "Welcome to My Practice Store"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f4f4f4"
    }
  ],
  "blocks": [
    {
      "type": "paragraph",
      "name": "Paragraph Block",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Content Text",
          "default": "This is dynamic block text."
        }
      ]
    },
    {
      "type": "button",
      "name": "Action Button",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Button Label",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Button Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Dynamic Banner",
      "blocks": [
        { "type": "paragraph" }
      ]
    }
  ]
}
{% endschema %}